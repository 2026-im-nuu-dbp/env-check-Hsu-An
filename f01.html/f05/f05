<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>白鹿｜藝人介紹</title>

<style>
/* ===== 基本設定 ===== */
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:"Microsoft JhengHei", sans-serif;
}

body{
    background:linear-gradient(135deg,#ffe6f0,#fff);
    color:#333;
    line-height:1.6;
}

/* ===== 導覽列 ===== */
nav{
    background:#6fffe7;
    padding:15px 0;
    position:sticky;
    top:0;
    z-index:1000;
}

nav ul{
    display:flex;
    justify-content:center;
    list-style:none;
}

nav ul li{
    margin:0 20px;
}

nav ul li a{
    color:white;
    text-decoration:none;
    font-weight:bold;
    transition:0.3s;
}

nav ul li a:hover{
    color:#ffe6f0;
}

/* ===== Hero 區塊 ===== */
.hero{
    height:90vh;
    background:url("https://i.imgur.com/7QbZ6Vn.jpg") center/cover no-repeat;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    color:white;
}

.hero h1{
    font-size:60px;
    background:rgba(0,0,0,0.4);
    padding:20px 40px;
    border-radius:10px;
}

/* ===== 區塊共用 ===== */
.section{
    padding:80px 20px;
    text-align:center;
}

.section h2{
    font-size:36px;
    margin-bottom:20px;
    color:#e92b7a;
}

/* ===== 卡片設計 ===== */
.card-container{
    display:flex;
    flex-wrap:wrap;
    justify-content:center;
    gap:20px;
    margin-top:40px;
}

.card{
    background:white;
    width:280px;
    padding:20px;
    border-radius:15px;
    box-shadow:0 5px 15px rgba(0,0,0,0.1);
    transition:0.3s;
}

.card:hover{
    transform:translateY(-10px);
}

button{
    margin-top:15px;
    padding:10px 20px;
    border:none;
    background:#ffcd6f;
    color:rgb(12, 0, 0);
    border-radius:20px;
    cursor:pointer;
    transition:0.3s;
    font-weight:700;
    text-decoration:wavy;
}

button:hover{
    background:#0ed80e;
}

/* ===== 圖片輪播 ===== */
.slider{
    margin-top:30px;
}

.slider img{
    width:300px;
    border-radius:15px;
    box-shadow:0 5px 15px rgba(0,0,0,0.2);
}

/* ===== 頁尾 ===== */
footer{
    background:#ff6fa5;
    color:white;
    padding:20px;
    text-align:center;
    margin-top:50px;
}

/* ===== 響應式 ===== */
@media(max-width:768px){
    .hero h1{
        font-size:40px;
    }
}
</style>
</head>

<body>

<!-- 導覽列 -->
<nav>
<ul>
<li><button type="button" onclick="location.href='#about'">關於白鹿</button></li>
<li><button type="button" onclick="location.href='#works'">代表作品</button></li>
<li><button type="button" onclick="location.href='#gallery'">寫真圖集</button></li>
</ul>
</nav>

<!-- Hero -->
<section class="hero">
<h1>白鹿 Bai Lu</h1>
</section>

<!-- 關於白鹿 -->
<section id="about" class="section">
<h2>關於白鹿</h2>
<p>
白鹿，本名白夢妍，中國內地女演員。以清新甜美的氣質與自然演技受到觀眾喜愛。
憑藉多部古裝與現代劇作品走紅，擁有高人氣與廣大粉絲群。
</p>
<button onclick="showMessage()">點擊了解更多</button>
</section>

<!-- 代表作品 -->
<section id="works" class="section">
<h2>代表作品</h2>

<div class="card-container">
<div class="card">
<h3>周生如故</h3>
<p>飾演 漼時宜</p>
</div>

<div class="card">
<h3>一生一世</h3>
<p>飾演 時宜</p>
</div>

<div class="card">
<h3>長月燼明</h3>
<p>飾演 黎蘇蘇 / 葉夕霧</p>
</div>
</div>

</section>

<!-- 圖片輪播 -->
<section id="gallery" class="section">
<h2>寫真圖集</h2>
<div class="slider">
<img id="sliderImage" src="https://i.imgur.com/7QbZ6Vn.jpg">
<br>
<button onclick="prevImage()">上一張</button>
<button onclick="nextImage()">下一張</button>
</div>
</section>

<footer>
© 2026 白鹿藝人介紹網站
</footer>

<script>
/* ===== 互動提示 ===== */
function showMessage(){
    alert("白鹿出生於1994年9月23日，代表作眾多，是備受矚目的新生代女演員！");
}

/* ===== 圖片輪播功能 ===== */
const images = [
"https://i.imgur.com/7QbZ6Vn.jpg",
"https://i.imgur.com/ZKRaK6K.jpg",
"https://i.imgur.com/Y4E4VtL.jpg"
];

let currentIndex = 0;

function showImage(index){
    document.getElementById("sliderImage").src = images[index];
}

function nextImage(){
    currentIndex++;
    if(currentIndex >= images.length){
        currentIndex = 0;
    }
    showImage(currentIndex);
}

function prevImage(){
    currentIndex--;
    if(currentIndex < 0){
        currentIndex = images.length - 1;
    }
    showImage(currentIndex);
}
</script>

</body>
</html>